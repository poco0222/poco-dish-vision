<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="oval">
            <size
                android:width="108dp"
                android:height="108dp" />
            <solid android:color="#0F4C81" />
        </shape>
    </item>

    <item
        android:top="22dp"
        android:left="22dp"
        android:right="22dp"
        android:bottom="22dp">
        <shape android:shape="rectangle">
            <corners android:radius="18dp" />
            <solid android:color="#FFF1D0" />
        </shape>
    </item>

    <item
        android:top="40dp"
        android:left="40dp"
        android:right="40dp"
        android:bottom="40dp">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="#E46B2C" />
        </shape>
    </item>

</layer-list>
